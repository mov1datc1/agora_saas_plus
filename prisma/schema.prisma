generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// User model for Supabase Auth integration and Stripe Billing
model User {
  id               String         @id @default(uuid())
  email            String         @unique
  name             String?
  stripeCustomerId String?        @unique
  role             Role           @default(USER)
  subscription     Subscription?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  copilotUsages    CopilotUsage[]
}

enum Role {
  USER
  ADMIN
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(TRIAL)
  priceId              String?
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

// AI Copilot Usage Tracking
model CopilotUsage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month     Int      // 1-12
  year      Int      // 2024, 2025, etc.
  queries   Int      @default(0) // Count of questions asked in this month
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month, year])
}

// SaaS Data Models
model Transaction {
  id            String   @id @default(uuid())
  title         String
  type          String   // M&A, Fusión, Venture Capital, etc.
  value         Decimal? @db.Decimal(15, 2)
  valueString   String?  // Ej. "No revelado", "$45.0M"
  status        String   // Anunciada, En Proceso, Completada
  country       String?
  dateAnnounced DateTime?
  dateClosed    DateTime?
  link          String?  // Enlace a LexLatin
  industryId    String?
  industry      Industry? @relation(fields: [industryId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  advisors      TransactionAdvisor[]
  lawyers       TransactionLawyer[]
  companies     TransactionCompany[]
}

model Industry {
  id            String   @id @default(uuid())
  name          String   @unique
  transactions  Transaction[]
}

model Company {
  id            String   @id @default(uuid())
  name          String
  country       String?
  transactions  TransactionCompany[]
}

model TransactionCompany {
  id            String   @id @default(uuid())
  transactionId String
  companyId     String
  role          String   // e.g. "Comprador", "Vendedor", "Target", "Emisor"

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([transactionId, companyId, role])
}


model Firm {
  id          String   @id @default(uuid())
  name        String   @unique
  country     String?
  website     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  lawyers     Lawyer[]
  transactions TransactionAdvisor[]
}

model Lawyer {
  id          String   @id @default(uuid())
  name        String
  firmId      String
  firm        Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)
  position    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions TransactionLawyer[]
}

model TransactionAdvisor {
  id            String      @id @default(uuid())
  transactionId String
  firmId        String
  role          String      // e.g. "Legal Advisor to Buyer"
  
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  firm          Firm        @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@unique([transactionId, firmId, role])
}

model TransactionLawyer {
  id            String      @id @default(uuid())
  transactionId String
  lawyerId      String
  role          String      // e.g. "Lead Counsel"
  
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  lawyer        Lawyer      @relation(fields: [lawyerId], references: [id], onDelete: Cascade)

  @@unique([transactionId, lawyerId, role])
}
