generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  name             String?
  stripeCustomerId String?        @unique
  role             Role           @default(USER)
  accountType      AccountType    @default(INDIVIDUAL)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  copilotUsages    CopilotUsage[]
  dailyUsages      DailyUsage[]
  subscription     Subscription?
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(TRIAL)
  priceId              String?
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CopilotUsage {
  id        String   @id @default(uuid())
  userId    String
  month     Int
  year      Int
  queries   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}

model EmailTemplate {
  id        String   @id @default(uuid())
  type      String   @unique
  subject   String
  htmlBody  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id            String               @id @default(uuid())
  title         String
  type          String
  value         Decimal?             @db.Decimal(15, 2)
  valueString   String?
  status        String
  country       String?
  dateAnnounced DateTime?
  dateClosed    DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  industryId    String?
  link          String?
  excerpt       String?
  industry      Industry?            @relation(fields: [industryId], references: [id])
  advisors      TransactionAdvisor[]
  companies     TransactionCompany[]
  lawyers       TransactionLawyer[]
}

model Industry {
  id           String        @id @default(uuid())
  name         String        @unique
  transactions Transaction[]
}

model Company {
  id           String               @id @default(uuid())
  name         String
  country      String?
  transactions TransactionCompany[]
}

model TransactionCompany {
  id            String      @id @default(uuid())
  transactionId String
  companyId     String
  role          String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@unique([transactionId, companyId, role])
}

model Firm {
  id           String               @id @default(uuid())
  name         String               @unique
  country      String?
  website      String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  lawyers      Lawyer[]
  transactions TransactionAdvisor[]
}

model Lawyer {
  id           String              @id @default(uuid())
  name         String
  firmId       String?
  position     String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  firm         Firm?               @relation(fields: [firmId], references: [id], onDelete: Cascade)
  transactions TransactionLawyer[]
}

model TransactionAdvisor {
  id            String      @id @default(uuid())
  transactionId String
  firmId        String
  role          String
  firm          Firm        @relation(fields: [firmId], references: [id], onDelete: Cascade)
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@unique([transactionId, firmId, role])
}

model TransactionLawyer {
  id            String      @id @default(uuid())
  transactionId String
  lawyerId      String
  role          String
  lawyer        Lawyer      @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@unique([transactionId, lawyerId, role])
}

model SystemConfig {
  id                       String   @id @default("global")
  trialRestrictionsEnabled Boolean  @default(false)
  gaMeasurementId          String?
  maintenanceModeEnabled   Boolean  @default(false)
  leadFormScript           String?  @db.Text
  updatedAt                DateTime @updatedAt
}

model DailyUsage {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime @db.Date
  queries   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum AccountType {
  INDIVIDUAL
  CORPORATE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

model SyncJob {
  id              String    @id @default(uuid())
  status          String    @default("RUNNING") // RUNNING, PAUSED, COMPLETED, CANCELLED, FAILED
  currentOffset   Int       @default(0)
  totalProcessed  Int       @default(0)
  skippedBlocks   Int       @default(0)
  targetUrl       String
  logs            String?   @db.Text
  startedAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  completedAt     DateTime?
}
